            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">def task_pattern = vars.get(&quot;task&quot;)
vars.put(&quot;task_name&quot;,task_pattern+&quot;_&quot;+ System.currentTimeMillis())
log.info(&quot;Task name is &quot; +  vars.get(&quot;task_name&quot;))
</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223Sampler>
